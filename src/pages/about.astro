---
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import TopBar from '../components/blocks/TopBar.astro';
import Footer from '../components/blocks/Footer.astro';
import FilmStripDivider from '../components/blocks/FilmStripDivider.astro';
import {
  SITE_TITLE,
  CTA_BOOKING_URL,
  CTA_COURSE_URL,
  CTA_COURSE_DISCOUNT_CODE,
} from '../consts';

// B Warm 設計 token
const C = {
  bg: '#FBFAF7',
  bgSoft: '#F4F1EB',
  ink: '#1F1B16',
  ink2: '#3D3A33',
  muted: '#6B6557',
  faint: '#A39C8C',
  rule: '#E8E2D4',
  accent: '#5391FF',
  accentDark: '#2F6FE0',
  accentSoft: '#EAF1FF',
  accentBg: '#F3F7FF',
  warm: '#D97706',
  warmSoft: '#FEF3E7',
  card: '#FFFFFF',
};
const sans = '"Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif';
const serif = '"Noto Serif TC", "Source Han Serif TC", serif';

// SEO
const aboutTitle = `關於我 ｜ ${SITE_TITLE}`;
const aboutDescription =
  'Dex，Daydream Dex 創辦人。轉職顧問 × AI 技術總監，10 年跨界 4 種專業，從半導體到資料工程、軟體、AI。輔導學員打造作品集、撰寫履歷、規劃職涯，陪你達到軟體和資料職涯目標。';

// 職涯時間軸（電影膠片）
const careerTimeline = [
  { period: '2019 — 2020', company: '台灣美光', role: 'Equipment Engineer', desc: '半導體製程，跨界的起點。', gradFrom: '#5391FF', gradTo: '#90B9FF', sceneNo: '01' },
  { period: '2019 — 2021', company: 'TutorABC', role: 'Big Data Engineer', desc: '走進資料工程的第一站。', gradFrom: '#0891B2', gradTo: '#67E8F9', sceneNo: '02' },
  { period: '2021', company: 'Line Bank', role: 'Data Engineer', desc: '金融級資料管線實戰。', gradFrom: '#7C3AED', gradTo: '#C4B5FD', sceneNo: '03' },
  { period: '2021 — 2025', company: '緯創資通', role: 'Backend Engineer', desc: '深耕後端與系統設計。', gradFrom: '#DB2777', gradTo: '#F9A8D4', sceneNo: '04' },
  { period: '2025 — 2026', company: '水球軟體學院', role: '成長行銷顧問', desc: '從技術走進品牌與成長。', gradFrom: '#D97706', gradTo: '#FCD34D', sceneNo: '05' },
  { period: '2026 — Now', company: 'HamaStar', role: 'Staff Engineer / AI 技術總監', desc: '帶領 AI 開發，做想做的事。', gradFrom: '#1F1B16', gradTo: '#5391FF', sceneNo: '06', highlight: true },
];

const sideRoles = [
  '擺渡職涯諮詢師',
  '學米面試作品集業師',
  '緯育雲端工程師講師、專題導師',
  'Podcaster：沒走歪的才奇怪',
  'AAPD 教練',
];

// 教練風格 4 大特色
const coachingStyles = [
  {
    title: '結構化引導',
    desc: '把模糊的問題拆成可理解的步驟，讓你看得見全貌、走得出第一步。',
    icon: 'compass',
    color: '#7C3AED',
    bg: '#F5F3FF',
  },
  {
    title: '為什麼而學',
    desc: '不只教技術，更聚焦目標與應用情境 —— 讓每一份學習，都有理由。',
    icon: 'seed',
    color: '#10B981',
    bg: '#ECFDF5',
  },
  {
    title: '技術 × 職涯 × 生涯',
    desc: '把能力，轉成職涯與生涯機會 —— 不只活下來，是活成你想要的樣子。',
    icon: 'lamp',
    color: '#D97706',
    bg: '#FEF3E7',
  },
  {
    title: '明確下一步行動',
    desc: '每次對談都帶走可執行的 next action 。不畫大餅，談的是這週怎麼動。',
    icon: 'paperplane',
    color: '#5391FF',
    bg: '#EAF1FF',
  },
];

// 5 大痛點
const painPoints = [
  { problem: '想轉職，但不確定路徑', solution: '釐清「目標 × 學習路徑 × 職涯策略」' },
  { problem: '想做作品集，但不知道從哪做起', solution: '從「情境 → 技術 → 專題」建立方向' },
  { problem: '學了技術，卻無法轉成職場能力', solution: '整合成「企業看得懂的作品集與經驗」' },
  { problem: '履歷投了沒回應', solution: '從「作品集 × 履歷 × 求職策略」找斷點' },
  { problem: '技術學習卡關', solution: '從「應用情境 × 整體脈絡」理解技術如何被使用' },
];

// 興趣
const interests = {
  movies: ['昆汀塔倫提諾', '大智若魚', '我的完美日常'],
  music: ['落日飛車', 'Deca joins', '無妄合作社'],
  podcasts: ['只能喝酒的圖書館', '台灣通勤第一品牌'],
};
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead />
    <SEO title={aboutTitle} description={aboutDescription} type="website" />
    <style is:global>
      body {
        margin: 0;
        background: #FBFAF7;
        color: #1F1B16;
        font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
      }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <div style={`background:${C.bg};color:${C.ink};font-family:${sans};min-height:100%;`}>

      <TopBar activePage="關於我" logoVariant="medium" />

      {/* ===================== Hero ===================== */}
      <section style="padding:90px 56px 60px;max-width:1240px;margin:0 auto;position:relative;overflow:hidden;">
        {/* 背景手繪小裝飾 */}
        <svg width="180" height="60" viewBox="0 0 180 60" style="position:absolute;top:60px;left:30px;opacity:0.5;">
          <path d="M5 30 Q 30 10, 60 28 T 120 28 T 175 25" fill="none" stroke={C.accent} stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 4"/>
        </svg>

        {/* 背景大號攝影機水印 */}
        <svg width="560" height="560" viewBox="0 0 32 32" style="position:absolute;top:-40px;right:-100px;opacity:0.05;pointer-events:none;">
          <g fill="none" stroke={C.ink} stroke-width="0.4" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="6" r="3.2"/><circle cx="9" cy="6" r="0.9"/>
            <circle cx="17" cy="6" r="3.2"/><circle cx="17" cy="6" r="0.9"/>
            <path d="M9 9.2v2M17 9.2v2"/>
            <rect x="3" y="11" width="18" height="11" rx="1.4"/>
            <circle cx="12" cy="16.5" r="3"/>
          </g>
        </svg>

        <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:56px;align-items:center;position:relative;">
          <div>
            <div style={`display:inline-flex;align-items:center;gap:10px;padding:8px 16px;background:${C.warmSoft};color:${C.warm};border-radius:999px;font-family:${sans};font-size:12px;font-weight:500;margin-bottom:24px;`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={C.warm} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l-5 7h10z"/>
                <ellipse cx="12" cy="16" rx="6" ry="4" opacity="0.5" stroke-dasharray="2 2"/>
                <path d="M12 10v3"/>
              </svg>
              ABOUT · SCENE 03 · 角色介紹
            </div>

            <h1 style={`font-family:${sans};font-size:54px;line-height:1.15;font-weight:800;color:${C.ink};letter-spacing:-1.5px;margin:0 0 24px;`}>
              一個從<span style={`background:linear-gradient(135deg, ${C.accent} 0%, ${C.accentDark} 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;`}>半導體</span>跨到 <span style={`color:${C.warm};`}>AI</span> 的<br/>
              長期主義者。
            </h1>

            <p style={`font-family:${serif};font-size:19px;line-height:1.95;color:${C.ink2};margin:0 0 28px;max-width:580px;`}>
              我是 Dex，Daydream Dex 創辦人。轉職顧問 × AI 技術總監，10 年跨界 4 種專業，從半導體到資料工程、軟體、AI。<br/>
              <span style={`color:${C.muted};font-size:17px;`}>輔導學員打造作品集、撰寫履歷、規劃職涯 —— 陪你達到軟體和資料職涯目標。</span>
            </p>

            <div style={`display:flex;gap:12px;font-family:${sans};align-items:center;flex-wrap:wrap;`}>
              <a href={CTA_BOOKING_URL} target="_blank" rel="noopener noreferrer" style={`display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:${C.accent};color:#fff;font-size:14px;font-weight:600;border-radius:10px;text-decoration:none;box-shadow:0 6px 20px rgba(83, 145, 255, 0.32);`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                </svg>
                預約一場諮詢
              </a>
              <a href={`mailto:hamastarkh@gmail.com`} style={`display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:${C.card};color:${C.ink};font-size:14px;font-weight:600;border-radius:10px;border:1px solid ${C.rule};text-decoration:none;`}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={C.ink} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/>
                </svg>
                寫封信給我
              </a>
              <span style={`font-family:${serif};font-size:13px;color:${C.faint};font-style:italic;margin-left:4px;`}>· 50 分鐘，不催促</span>
            </div>
          </div>

          {/* 右側 — Dex 大頭像區（真實照片）*/}
          <div style="position:relative;height:420px;display:flex;align-items:center;justify-content:center;">
            {/* 漸層光暈背景 */}
            <div style={`position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:340px;height:340px;border-radius:50%;background:radial-gradient(circle, ${C.accentSoft} 0%, ${C.warmSoft} 60%, transparent 100%);opacity:0.7;`}></div>

            {/* 真實照片 — 圓角矩形 */}
            <div style={`position:relative;width:300px;height:380px;border-radius:24px;overflow:hidden;box-shadow:0 24px 60px rgba(83,145,255,0.22), 0 8px 16px rgba(0,0,0,0.12);border:4px solid #fff;`}>
              <img src="/photos/dex-portrait-1.png" alt="Dex" style="width:100%;height:100%;object-fit:cover;display:block;" />
              <div style={`position:absolute;bottom:0;left:0;right:0;padding:14px 18px 12px;background:linear-gradient(transparent, rgba(0,0,0,0.55));color:#fff;font-family:${sans};font-size:10.5px;letter-spacing:2px;font-weight:600;`}>DAYDREAM · DEX</div>
            </div>

            {/* 浮動小卡 — 38 歲 */}
            <div style={`position:absolute;top:30px;right:-10px;padding:12px 16px;background:${C.card};border-radius:12px;border:1px solid ${C.rule};box-shadow:0 8px 24px rgba(0,0,0,0.08);transform:rotate(4deg);font-family:${sans};font-size:12px;color:${C.ink};display:flex;align-items:center;gap:10px;`}>
              <span style={`width:8px;height:8px;border-radius:50%;background:${C.warm};`}></span>
              <div>
                <div style={`font-weight:600;color:${C.ink};`}>跨界 10 年</div>
                <div style={`font-family:${serif};font-size:11px;color:${C.muted};font-style:italic;margin-top:2px;`}>4 種專業 · 還在路上</div>
              </div>
            </div>

            {/* 浮動小卡 — 諮詢狀態 */}
            <div style={`position:absolute;bottom:40px;left:-20px;padding:12px 16px;background:${C.ink};color:#fff;border-radius:12px;font-family:${sans};font-size:12px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 24px rgba(0,0,0,0.18);transform:rotate(-3deg);`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/>
              </svg>
              <div>
                <div style="font-weight:600;">本月還有時段</div>
                <div style="opacity:0.7;font-size:10px;margin-top:1px;">不勉強，有需要再來</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ===================== 膠捲分隔線 ===================== */}
      <div style="max-width:1120px;margin:0 auto;padding:0 56px;">
        <FilmStripDivider />
      </div>

      {/* ===================== 自介長版 (CV-Story) ===================== */}
      <section style="padding:60px 56px 40px;max-width:880px;margin:0 auto;position:relative;">
        <div style={`display:inline-flex;align-items:center;gap:10px;font-family:${serif};font-size:13px;color:${C.muted};font-style:italic;letter-spacing:3px;margin-bottom:24px;`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={C.muted} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <circle cx="12" cy="12" r="1.6" fill={C.muted}/>
            <circle cx="12" cy="6" r="1.4"/><circle cx="12" cy="18" r="1.4"/>
            <circle cx="6" cy="12" r="1.4"/><circle cx="18" cy="12" r="1.4"/>
          </svg>
          —— MY STORY ——
        </div>
        <div style={`font-family:${serif};font-size:18px;line-height:2;color:${C.ink2};max-width:760px;`}>
          <p style="margin:0 0 1.4em;">
            6 年多前我從<span style={`color:${C.ink};font-weight:600;`}>半導體設備工程師</span>轉職，經歷大數據、軟體後端開發，到現在成為<span style={`color:${C.ink};font-weight:600;`}>AI 技術開發的 Tech Lead</span>。
          </p>
          <p style="margin:0 0 1.4em;">
            這段過程讓我理解「<span style={`background:linear-gradient(transparent 70%, ${C.warmSoft} 70%);`}>學習技術</span>」到「<span style={`background:linear-gradient(transparent 70%, ${C.warmSoft} 70%);`}>進入職場</span>」之間的落差，因此我開始投入職涯輔導，協助作品集指導、專題陪跑與轉職策略 —— 把能力轉化為具體成果與職場價值。
          </p>
          <p style="margin:0 0 1.4em;">
            過去曾在 Alpha Camp、六角學院、學米等協助學員成長，也是緯育「雲端資料工程師線上班」的課程講師與專題導師。
          </p>
          <p style="margin:0;">
            因為自己的親身經歷，我了解在不同階段會遇到的迷惘。我會陪伴在各種層面卡關的人 —— 無論是學習方向、作品集、斜槓專案或求職轉職問題 —— 一起把問題釐清、整合技能，<span style={`color:${C.ink};font-weight:600;`}>逐步走出一條清晰可行的路</span>。
          </p>
        </div>
      </section>

      {/* ===================== 職涯時間軸（電影膠片）===================== */}
      <section style="padding:60px 56px 40px;max-width:1240px;margin:0 auto;position:relative;">
        {/* 場記板裝飾 */}
        <div style="position:absolute;top:24px;right:48px;transform:rotate(8deg);opacity:0.7;">
          <svg width="120" height="90" viewBox="0 0 200 150">
            <rect x="6" y="0" width="188" height="36" rx="3" fill={C.ink}/>
            {Array.from({ length: 8 }).map((_, i) => (
              <polygon points={`${10 + i * 24},2 ${28 + i * 24},2 ${22 + i * 24},34 ${4 + i * 24},34`} fill="white"/>
            ))}
            <rect x="6" y="42" width="188" height="100" rx="3" fill={C.ink}/>
            <text x="20" y="72" font-family={sans} font-size="10" fill="#fff" letter-spacing="1" opacity="0.6">SCENE</text>
            <text x="20" y="98" font-family={sans} font-size="18" font-weight="700" fill="#fff">CAREER</text>
            <text x="20" y="118" font-family={sans} font-size="9" fill="#fff" opacity="0.6">DIRECTOR · DEX</text>
          </svg>
        </div>

        <div style="margin-bottom:36px;">
          <div style={`font-family:${serif};font-size:13px;color:${C.accent};font-style:italic;letter-spacing:2px;margin-bottom:8px;`}>—— TIMELINE · 跨界 10 年 ——</div>
          <h2 style={`font-family:${sans};font-size:34px;font-weight:700;color:${C.ink};margin:0;letter-spacing:-1px;`}>從半導體到 AI，我走過的這條路</h2>
          <p style={`font-family:${serif};font-size:15px;color:${C.muted};margin:10px 0 0;max-width:580px;line-height:1.7;`}>
            6 家公司、4 種專業 —— 每一段都不是速成，但都教了我一些關鍵的事。每一格都是一場戲。
          </p>
        </div>

        {/* 電影膠片：橫向滾動容器 */}
        <div style={`position:relative;background:${C.ink};border-radius:14px;padding:18px 0;box-shadow:0 12px 36px rgba(0,0,0,0.18);`}>
          {/* 上排齒孔 */}
          <div style="display:flex;justify-content:space-around;padding:0 12px 10px;">
            {Array.from({ length: 24 }).map(() => (
              <div style={`width:14px;height:10px;background:${C.bg};border-radius:2px;flex-shrink:0;`}></div>
            ))}
          </div>

          {/* 影格列 */}
          <div style="overflow-x:auto;padding:0 16px;">
            <div style="display:flex;gap:14px;min-width:max-content;padding:6px 0;">
              {careerTimeline.map((row) => (
                <div style={`width:230px;flex-shrink:0;background:#fff;border-radius:8px;overflow:hidden;border:3px solid ${row.highlight ? C.warm : '#fff'};box-shadow:0 4px 14px rgba(0,0,0,0.25);position:relative;`}>
                  {/* 影格頂部色帶 */}
                  <div style={`height:96px;background:linear-gradient(135deg, ${row.gradFrom} 0%, ${row.gradTo} 100%);position:relative;display:flex;align-items:center;justify-content:center;`}>
                    {/* SCENE 標記 */}
                    <div style={`position:absolute;top:8px;left:8px;padding:3px 8px;background:rgba(0,0,0,0.55);color:#fff;font-family:${sans};font-size:9px;font-weight:700;letter-spacing:1.5px;border-radius:3px;`}>SCENE {row.sceneNo}</div>
                    {row.highlight && (
                      <div style={`position:absolute;top:8px;right:8px;padding:3px 8px;background:${C.warm};color:#fff;font-family:${sans};font-size:9px;font-weight:800;letter-spacing:1.5px;border-radius:3px;transform:rotate(4deg);box-shadow:0 2px 6px rgba(217,119,6,0.5);`}>NOW</div>
                    )}
                    {/* 公司大字 */}
                    <div style={`font-family:${serif};font-size:22px;font-weight:700;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,0.3);text-align:center;padding:0 12px;line-height:1.25;`}>{row.company}</div>
                  </div>
                  {/* 資訊區 */}
                  <div style="padding:14px 16px 16px;">
                    <div style={`font-family:${serif};font-size:11px;color:${row.highlight ? C.warm : C.faint};font-style:italic;letter-spacing:1px;margin-bottom:6px;font-weight:${row.highlight ? 600 : 500};`}>{row.period}</div>
                    <div style={`font-family:${sans};font-size:14px;font-weight:700;color:${C.ink};margin-bottom:4px;letter-spacing:-0.2px;`}>{row.role}</div>
                    <div style={`font-family:${serif};font-size:12px;color:${C.muted};line-height:1.6;`}>{row.desc}</div>
                  </div>
                  {/* 影格編號 */}
                  <div style={`position:absolute;bottom:8px;right:10px;font-family:${serif};font-size:10px;color:${C.faint};font-style:italic;`}>—— {row.sceneNo} / 06 ——</div>
                </div>
              ))}
            </div>
          </div>

          {/* 下排齒孔 */}
          <div style="display:flex;justify-content:space-around;padding:10px 12px 0;">
            {Array.from({ length: 24 }).map(() => (
              <div style={`width:14px;height:10px;background:${C.bg};border-radius:2px;flex-shrink:0;`}></div>
            ))}
          </div>
        </div>

        {/* 膠片底部說明 */}
        <div style={`margin-top:18px;display:flex;align-items:center;justify-content:space-between;font-family:${serif};font-size:12px;color:${C.faint};font-style:italic;`}>
          <span>—— ROLL · A · 2019 ~ 2026 · 6 SCENES ——</span>
          <span style="display:inline-flex;align-items:center;gap:6px;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke={C.faint} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
