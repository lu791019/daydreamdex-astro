---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import SEO from '../../components/SEO.astro';
import TopBar from '../../components/blocks/TopBar.astro';
import Footer from '../../components/blocks/Footer.astro';
import NewsletterFloatingCTA from '../../components/blocks/NewsletterFloatingCTA.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;

const C = {
  bg: '#FBFAF7',
  bgSoft: '#F4F1EB',
  ink: '#1F1B16',
  ink2: '#3D3A33',
  muted: '#6B6557',
  faint: '#A39C8C',
  rule: '#E8E2D4',
  accent: '#5391FF',
  accentDark: '#2F6FE0',
  accentSoft: '#EAF1FF',
  warm: '#D97706',
  warmSoft: '#FEF3E7',
  card: '#FFFFFF',
};
const sans = '"Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif';
const serif = '"Noto Serif TC", "Source Han Serif TC", serif';

const blogTitle = `所有文章 ｜ ${SITE_TITLE}`;
const blogDescription = 'Dex 的塵世筆記 —— 軟體、資料工程、AI、轉職、跨界的長思考。慢慢看，我們有的是時間。';
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead />
    <SEO title={blogTitle} description={blogDescription} type="website" />
    <style is:global>
      body {
        margin: 0;
        background: #FBFAF7;
        color: #1F1B16;
        font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
      }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <div style={`background:${C.bg};color:${C.ink};font-family:${sans};min-height:100vh;`}>

      <TopBar activePage="文章" logoVariant="medium" />

      {/* ===================== Hero ===================== */}
      <section style="padding:80px 56px 40px;max-width:1100px;margin:0 auto;text-align:center;">
        {/* SCENE 引言塊 */}
        <div style={`display:inline-flex;align-items:center;gap:10px;background:${C.ink};color:${C.bg};padding:6px 16px;border-radius:6px;font-family:${sans};font-weight:700;letter-spacing:2px;font-size:12px;margin-bottom:24px;`}>
          <span style={`width:7px;height:7px;border-radius:50%;background:${C.warm};`}></span>
          SCENE · ARCHIVE
        </div>

        <h1 style={`font-family:${sans};font-size:54px;font-weight:800;letter-spacing:-1.2px;line-height:1.2;margin:0 0 18px;`}>
          所有文章
        </h1>
        <p style={`font-family:${serif};font-size:17px;color:${C.muted};line-height:1.85;font-style:italic;max-width:560px;margin:0 auto;`}>
          {blogDescription}
        </p>
      </section>

      {/* ===================== Featured（最新一篇）===================== */}
      {featured && (
        <section style="padding:0 56px 60px;max-width:1100px;margin:0 auto;">
          <a href={`/blog/${featured.id}/`} style={`display:block;text-decoration:none;background:${C.card};border:1px solid ${C.rule};border-radius:18px;overflow:hidden;box-shadow:0 12px 32px rgba(31,27,22,0.06);`}>
            <div style="display:grid;grid-template-columns:1.1fr 1fr;align-items:stretch;">
              {/* 圖 */}
              {featured.data.heroImage ? (
                <div style="aspect-ratio:4/3;overflow:hidden;background:#000;">
                  <img src={featured.data.heroImage} alt={featured.data.title} loading="eager" style="width:100%;height:100%;object-fit:cover;display:block;" />
                </div>
              ) : (
                <div style={`aspect-ratio:4/3;background:linear-gradient(135deg, ${C.accentSoft}, ${C.warmSoft});`}></div>
              )}

              {/* 內容 */}
              <div style="padding:36px 38px;display:flex;flex-direction:column;justify-content:center;">
                <div style={`display:inline-flex;align-items:center;gap:6px;font-family:${serif};font-size:11px;color:${C.warm};letter-spacing:2px;font-style:italic;margin-bottom:14px;font-weight:700;`}>
                  <span style="width:6px;height:6px;border-radius:50%;background:#DC2626;display:inline-block;"></span>
                  NOW SHOWING · 最新一篇
                </div>
                <h2 style={`font-family:${sans};font-size:28px;line-height:1.4;font-weight:800;color:${C.ink};letter-spacing:-0.5px;margin:0 0 14px;`}>
                  {featured.data.title}
                </h2>
                <p style={`font-family:${serif};font-size:15px;color:${C.muted};line-height:1.85;margin:0 0 18px;`}>
                  {featured.data.description}
                </p>
                <div style={`display:flex;align-items:center;gap:14px;font-family:${sans};font-size:13px;color:${C.faint};`}>
                  <span style="display:inline-flex;align-items:center;gap:6px;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                    </svg>
                    <FormattedDate date={featured.data.pubDate} />
                  </span>
                  <span style={`color:${C.accent};font-weight:600;display:inline-flex;align-items:center;gap:4px;`}>
                    閱讀全文
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </section>
      )}

      {/* ===================== 膠捲分隔線 ===================== */}
      <div style="max-width:1100px;margin:0 auto;padding:0 56px 24px;">
        <div style="display:flex;align-items:center;gap:14px;">
          <span style={`font-family:${serif};font-size:12px;color:${C.faint};font-style:italic;letter-spacing:1.5px;flex-shrink:0;`}>—— 其他文章 ——</span>
          <div style={`flex:1;height:1px;background:repeating-linear-gradient(90deg, ${C.rule}, ${C.rule} 6px, transparent 6px, transparent 12px);`}></div>
        </div>
      </div>

      {/* ===================== Grid 列表 ===================== */}
      <section style="padding:0 56px 80px;max-width:1100px;margin:0 auto;">
        <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:32px;">
          {rest.map((post) => (
            <a href={`/blog/${post.id}/`} style={`display:flex;flex-direction:column;gap:16px;text-decoration:none;background:${C.card};border:1px solid ${C.rule};border-radius:14px;overflow:hidden;transition:transform 220ms ease, box-shadow 220ms ease;`} class="blog-card">
              {post.data.heroImage ? (
                <div style="aspect-ratio:16/9;overflow:hidden;background:#000;">
                  <img src={post.data.heroImage} alt={post.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
                </div>
              ) : (
                <div style={`aspect-ratio:16/9;background:linear-gradient(135deg, ${C.accentSoft}, ${C.warmSoft});`}></div>
              )}
              <div style="padding:0 22px 22px;">
                <h3 style={`font-family:${sans};font-size:19px;font-weight:700;color:${C.ink};letter-spacing:-0.3px;line-height:1.45;margin:0 0 10px;`}>
                  {post.data.title}
                </h3>
                <p style={`font-family:${serif};font-size:14px;color:${C.muted};line-height:1.85;margin:0 0 14px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;`}>
                  {post.data.description}
                </p>
                <div style={`font-family:${sans};font-size:12px;color:${C.faint};display:inline-flex;align-items:center;gap:6px;`}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                  </svg>
                  <FormattedDate date={post.data.pubDate} />
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <Footer />

    </div>

    <NewsletterFloatingCTA />

    <style>
      .blog-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 40px rgba(31,27,22,0.10);
      }
    </style>
  </body>
</html>
