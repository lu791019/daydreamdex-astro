---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return posts.map((post, idx) => ({
		params: { slug: post.id },
		props: {
			post,
			// 較新的文章在前面，所以 idx-1 是 newer / idx+1 是 older
			newer: idx > 0 ? posts[idx - 1] : null,
			older: idx < posts.length - 1 ? posts[idx + 1] : null,
		},
	}));
}

type Props = {
	post: CollectionEntry<'blog'>;
	newer: CollectionEntry<'blog'> | null;
	older: CollectionEntry<'blog'> | null;
};

const { post, newer, older } = Astro.props;
const { Content, headings } = await render(post);

const newerLink = newer ? { slug: newer.id, title: newer.data.title } : null;
const olderLink = older ? { slug: older.id, title: older.data.title } : null;

// 只取 H2 / H3 進 TOC（H1 是文章標題、H4+ 太細不放）
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BlogPost {...post.data} newer={newerLink} older={olderLink} headings={tocHeadings}>
	<Content />
</BlogPost>
