            const inkColor = '#1F1B16';
            const cardColor = '#FFFFFF';
            const ink2Color = '#3D3A33';
            const ruleColor = '#E8E2D4';

            function setActive(btn) {
              buttons.forEach((b) => {
                if (b === btn) {
                  b.style.background = inkColor;
                  b.style.color = '#fff';
                  b.style.fontWeight = '600';
                  b.style.boxShadow = 'none';
                  b.classList.add('filter-active');
                } else {
                  b.style.background = cardColor;
                  b.style.color = ink2Color;
                  b.style.fontWeight = '500';
                  b.style.boxShadow = 'inset 0 0 0 1px ' + ruleColor;
                  b.classList.remove('filter-active');
                }
              });
            }

            buttons.forEach((btn) => {
              btn.addEventListener('click', function () {
                const filter = btn.getAttribute('data-filter');
                setActive(btn);
                posts.forEach((p) => {
                  const tag = p.getAttribute('data-tag');
                  const show = filter === 'all' || tag === filter;
                  p.style.display = show ? 'grid' : 'none';
                });
              });
            });
