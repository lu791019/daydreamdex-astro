---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import TopBar from '../components/blocks/TopBar.astro';
import Footer from '../components/blocks/Footer.astro';
import FilmStripDivider from '../components/blocks/FilmStripDivider.astro';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  HERO_TAGLINE,
  FEATURED_POST_SLUGS,
  CTA_BOOKING_URL,
} from '../consts';

// ===== Color & Font tokens (對應 W_C / W_sans / W_serif) =====
const C = {
  bg: '#FBFAF7',
  bgSoft: '#F4F1EB',
  ink: '#1F1B16',
  ink2: '#3D3A33',
  muted: '#6B6557',
  faint: '#A39C8C',
  rule: '#E8E2D4',
  accent: '#5391FF',
  accentDark: '#2F6FE0',
  accentSoft: '#EAF1FF',
  accentBg: '#F3F7FF',
  warm: '#D97706',
  warmSoft: '#FEF3E7',
  card: '#FFFFFF',
};
const sans = '"Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif';
const serif = '"Noto Serif TC", "Source Han Serif TC", serif';

// ===== 撈文章 =====
const allPostsRaw = await getCollection('blog', (p) => !p.data.draft);
const allPosts = allPostsRaw.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 取出 URL slug（保留完整 id，含日期前綴 — 對應 [...slug].astro 的 getStaticPaths）
function postUrlSlug(id: string): string {
  return id.replace(/\.mdx?$/, '');
}

// 分類映射：根據 title + description 推斷 tag
type TagInfo = { tag: string; tagColor: string };
function inferTag(title: string, desc: string): TagInfo {
  const text = (title + desc).toLowerCase();
  if (/ai|llm|langchain|機器學習|machine learning/.test(text)) {
    return { tag: 'AI', tagColor: '#DB2777' };
  }
  if (/資料工程|data engineer|nosql|spark|sql|資料分析|data analyst/.test(text)) {
    return { tag: '資料工程', tagColor: '#0891B2' };
  }
  if (/轉職|python|career|程式|入門|新手/.test(text)) {
    return { tag: '轉職', tagColor: '#5391FF' };
  }
  if (/休息|時間|志業|人生|長期/.test(text)) {
    return { tag: '心法', tagColor: '#D97706' };
  }
  return { tag: '職涯', tagColor: '#5391FF' };
}

// Featured 5 篇
const coverIds = ['g1', 'g2', 'g3', 'g4', 'g5'];
const iconNames = ['clapper', 'seed', 'filmreel', 'lamp', 'paperplane'];
const featured = FEATURED_POST_SLUGS.map((slug, i) => {
  const post = allPosts.find((p) => p.id.includes(slug));
  if (!post) return null;
  const tagInfo = inferTag(post.data.title, post.data.description);
  return {
    slug: postUrlSlug(post.id),
    title: post.data.title,
    desc: post.data.description,
    tag: tagInfo.tag,
    tagColor: tagInfo.tagColor,
    cover: coverIds[i],
    iconName: iconNames[i],
    stats: `${10 + i * 3} 分鐘 · 真心話`,
    heroImage: post.data.heroImage as string | undefined,
  };
}).filter((p): p is NonNullable<typeof p> => p !== null);

// 全部文章列表
const posts = allPosts.map((p) => {
  const d = p.data.pubDate;
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  const tagInfo = inferTag(p.data.title, p.data.description);
  return {
    slug: postUrlSlug(p.id),
    title: p.data.title,
    desc: p.data.description,
    date: `${mm} / ${dd}`,
    year: String(d.getFullYear()),
    tag: tagInfo.tag,
    tagColor: tagInfo.tagColor,
  };
});

const totalPosts = posts.length;
const remainingPosts = Math.max(0, totalPosts - 9);

// 分類計數
const catCount = {
  轉職: posts.filter((p) => p.tag === '轉職').length,
  資料工程: posts.filter((p) => p.tag === '資料工程').length,
  AI: posts.filter((p) => p.tag === 'AI').length,
  心法: posts.filter((p) => p.tag === '心法').length,
};

// Cinema 區假影評（保留設計值）
const reviews = [
  { title: '《進擊的鼓手》看「夠不夠好」的執念', tag: '影評 × 心法', mood: '#DB2777', moodSoft: '#FCE7F3', meta: '12 分鐘 · 8.4k 閱讀' },
  { title: '《教父》教我的職場政治學', tag: '影評 × 職涯', mood: '#7C3AED', moodSoft: '#F5F3FF', meta: '15 分鐘 · 6.1k 閱讀' },
  { title: '《模仿遊戲》與當代 AI 工程師', tag: '影評 × AI', mood: '#0891B2', moodSoft: '#E0F2FE', meta: '18 分鐘 · 11.2k 閱讀' },
];

// 漸層卡片色配對
const grads: Record<string, [string, string]> = {
  g1: ['#5391FF', '#90B9FF'],
  g2: ['#7C3AED', '#C4B5FD'],
  g3: ['#0891B2', '#67E8F9'],
  g4: ['#DB2777', '#F9A8D4'],
  g5: ['#D97706', '#FCD34D'],
};

// Hero 漂浮卡 - 本週新文 (取最新一篇)
const latest = posts[0];

// 給正在轉職的你 區塊 CTA 用第一篇 featured
const forYouLink = featured[0] ? `/blog/${featured[0].slug}` : '/blog';
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead />
    <SEO title={SITE_TITLE} description={SITE_DESCRIPTION} type="website" />
    <style is:global>
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }
      body {
        margin: 0;
        background: #FBFAF7;
        color: #1F1B16;
        font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
      }
      a { color: inherit; }
      input::placeholder { color: #A39C8C; }
    </style>
  </head>
  <body>
    <div style={`background:${C.bg};color:${C.ink};font-family:${sans};min-height:100%;width:100%;`}>

      <TopBar activePage="文章" logoVariant="full" showUtilityButtons={true} />

      {/* ===================== W_Hero ===================== */}
      <section style="padding:90px 56px 70px;max-width:1240px;margin:0 auto;position:relative;overflow:hidden;">
        {/* 背景手繪小裝飾 */}
        <svg width="180" height="60" viewBox="0 0 180 60" style="position:absolute;top:60px;left:30px;opacity:0.5;">
          <path d="M5 30 Q 30 10, 60 28 T 120 28 T 175 25" fill="none" stroke={C.accent} stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 4"/>
        </svg>

        {/* 背景超大號攝影機輪廓水印 */}
        <svg width="640" height="640" viewBox="0 0 32 32" style="position:absolute;top:-40px;right:-120px;opacity:0.05;pointer-events:none;">
          <g fill="none" stroke={C.ink} stroke-width="0.4" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="6" r="3.2"/><circle cx="9" cy="6" r="0.9"/>
            <circle cx="17" cy="6" r="3.2"/><circle cx="17" cy="6" r="0.9"/>
            <path d="M9 9.2v2M17 9.2v2"/>
            <rect x="3" y="11" width="18" height="11" rx="1.4"/>
            <circle cx="12" cy="16.5" r="3"/>
            <circle cx="12" cy="16.5" r="1.2"/>
            <rect x="18" y="13" width="2" height="2" rx="0.3"/>
            <path d="M21 14l5-2v8l-5-2z"/>
          </g>
        </svg>

        <div style="display:grid;grid-template-columns:1fr 460px;gap:56px;align-items:center;position:relative;">
          <div>
            {/* 大型場記板 */}
            <div style="position:relative;width:fit-content;margin-bottom:18px;transform:rotate(-3deg);">
              <svg width="200" height="150" viewBox="0 0 200 150" style="filter:drop-shadow(0 8px 16px rgba(0,0,0,0.12));">
                <g transform="translate(0 0)">
                  <rect x="6" y="0" width="188" height="36" rx="3" fill={C.ink}/>
                  {Array.from({ length: 8 }).map((_, i) => (
                    <polygon points={`${10 + i * 24},2 ${28 + i * 24},2 ${22 + i * 24},34 ${4 + i * 24},34`} fill="white"/>
                  ))}
                  <circle cx="14" cy="40" r="3" fill={C.ink}/>
                  <rect x="6" y="36" width="188" height="6" fill={C.ink}/>
                </g>
                <rect x="6" y="42" width="188" height="100" rx="3" fill={C.ink}/>
                <g font-family={sans} fill="white">
                  <text x="20" y="66" font-size="9" opacity="0.55" letter-spacing="1">PROD.</text>
                  <text x="20" y="82" font-size="14" font-weight="700">DAYDREAM DEX</text>
                  <line x1="20" y1="90" x2="180" y2="90" stroke="white" stroke-width="0.5" opacity="0.3"/>
                  <text x="20" y="105" font-size="8" opacity="0.55" letter-spacing="1">SCENE</text>
                  <text x="55" y="106" font-size="11" font-family={serif}>132</text>
                  <text x="100" y="105" font-size="8" opacity="0.55" letter-spacing="1">TAKE</text>
                  <text x="135" y="106" font-size="11" font-family={serif}>01</text>
                  <line x1="20" y1="113" x2="180" y2="113" stroke="white" stroke-width="0.5" opacity="0.3"/>
                  <text x="20" y="128" font-size="8" opacity="0.55" letter-spacing="1">DIRECTOR</text>
                  <text x="68" y="129" font-family={serif} font-size="10" font-style="italic">Dex</text>
                  <text x="100" y="128" font-size="8" opacity="0.55" letter-spacing="1">ROLL</text>
                  <text x="135" y="129" font-family={serif} font-size="10" font-style="italic">2026</text>
                </g>
              </svg>
              {/* ACTION! 印章 */}
              <div style={`position:absolute;top:-8px;right:-34px;transform:rotate(15deg);padding:4px 10px;background:#DC2626;color:#fff;font-family:${sans};font-size:11px;font-weight:800;letter-spacing:2px;border:2px solid #fff;box-shadow:0 3px 8px rgba(220,38,38,0.4);`}>ACTION!</div>
            </div>

            <div style={`display:inline-flex;align-items:center;gap:10px;padding:8px 16px;background:${C.warmSoft};color:${C.warm};border-radius:999px;font-family:${sans};font-size:12px;font-weight:500;margin-bottom:28px;`}>
              {/* SVGSpotlight */}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={C.warm} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l-5 7h10z"/>
                <ellipse cx="12" cy="16" rx="6" ry="4" opacity="0.5" stroke-dasharray="2 2"/>
                <path d="M12 10v3"/>
              </svg>
              工程師 × 影評人 · {totalPosts} 篇給工程師的長信
            </div>
            <h1 style={`font-family:${sans};font-size:64px;line-height:1.08;font-weight:800;color:${C.ink};letter-spacing:-1.8px;margin:0;`}>
              慢慢走,<br/>
              一起把<span style="position:relative;display:inline-block;">
                <span style={`background:linear-gradient(135deg, ${C.accent} 0%, ${C.accentDark} 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;`}>軟體職涯</span>
                <svg width="260" height="10" viewBox="0 0 260 10" style="display:block;margin-top:-6px;">
                  <path d="M2 6 Q 65 1, 130 5 T 258 4" fill="none" stroke={C.accent} stroke-width="2.5" stroke-linecap="round" opacity="0.55"/>
                </svg>
              </span><br/>
              走成一條長路。
            </h1>

            {/* 第一句電影台詞 SCENE 01 */}
            <div style={`margin-top:28px;padding:16px 20px;background:rgba(255,255,255,0.6);border-left:3px solid ${C.warm};border-radius:0 10px 10px 0;max-width:560px;`}>
              <div style={`display:flex;align-items:center;gap:8px;font-family:${serif};font-size:11px;color:${C.warm};font-style:italic;letter-spacing:1.5px;margin-bottom:6px;`}>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke={C.warm} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2.5" y="8" width="19" height="12" rx="1.4"/>
                  <path d="M2.5 8L5 4l3 3.6L8.5 4l3 3.6L12 4l3 3.6L15.5 4l3 3.6L19 4l2.5 4"/>
                  <path d="M2.5 12h19" opacity="0.4"/>
                </svg>
                SCENE 01 · 起點
              </div>
              <div style={`font-family:${serif};font-size:16px;color:${C.ink2};line-height:1.7;font-style:italic;`}>
                “Now you can know everything in the world, but the only way you're finding out that one is by giving it a shot.”
              </div>
            </div>

            <p style={`font-family:${serif};font-size:19px;line-height:1.85;color:${C.ink2};margin-top:28px;font-weight:400;max-width:560px;`}>
              這裡是 Dex 的塵世筆記 —— 寫給每個正在<br/>
              軟體工程、資料工程、AI 路上的你。<br/>
              <span style={`color:${C.muted};font-size:17px;`}>偶爾,我們也聊聊電影裡的人生。</span>
            </p>

            <div style={`display:flex;gap:12px;margin-top:36px;font-family:${sans};align-items:center;`}>
              <a href="#all-posts" style={`display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:${C.accent};color:#fff;font-size:14px;font-weight:600;border-radius:10px;text-decoration:none;box-shadow:0 6px 20px rgba(83, 145, 255, 0.32);`}>
                從一篇文章開始
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
              <a href={CTA_BOOKING_URL} target="_blank" rel="noopener noreferrer" style={`display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:${C.card};color:${C.ink};font-size:14px;font-weight:600;border-radius:10px;border:1px solid ${C.rule};text-decoration:none;`}>
                {/* SVGPaperPlane */}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={C.ink} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/>
                </svg>
                預約一場諮詢
              </a>
              <span style={`font-family:${serif};font-size:13px;color:${C.faint};font-style:italic;margin-left:4px;`}>· 50 分鐘,不催促</span>
            </div>

            {/* 三個小承諾 */}
            <div style={`margin-top:48px;padding-top:32px;border-top:1px dashed ${C.rule};`}>
              <div style={`font-family:${serif};font-size:13px;color:${C.muted};font-style:italic;margin-bottom:14px;`}>—— 在這裡,我答應你 ——</div>
              <div style="display:flex;flex-direction:column;gap:8px;">
                {[
                  '不寫 SEO 廢文,每篇都是真心話',
                  '不販賣轉職焦慮,只談長期可持續的路徑',
                  '回信慢一點,但每一封都會親自回',
                ].map((t) => (
                  <div style={`display:flex;align-items:center;gap:10px;font-family:${sans};font-size:14px;color:${C.ink2};`}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={C.accent} stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {t}
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Hero 右側大攝影機 */}
          <div style="position:relative;height:540px;">
            <svg width="460" height="380" viewBox="0 0 320 260" style="position:absolute;top:20px;right:0;filter:drop-shadow(0 24px 40px rgba(83,145,255,0.18)) drop-shadow(0 6px 12px rgba(0,0,0,0.06));">
              {/* 三腳架 */}
              <g stroke={C.ink} stroke-width="3" stroke-linecap="round" fill="none">
                <line x1="160" y1="195" x2="160" y2="245"/>
                <line x1="160" y1="245" x2="120" y2="258"/>
                <line x1="160" y1="245" x2="200" y2="258"/>
                <line x1="160" y1="245" x2="160" y2="258"/>
                <line x1="125" y1="258" x2="195" y2="258"/>
              </g>
              <rect x="148" y="185" width="24" height="14" rx="2" fill={C.ink}/>

              {/* 機身 */}
              <rect x="40" y="80" width="200" height="105" rx="6" fill="#fff" stroke={C.ink} stroke-width="2.5"/>
              <rect x="44" y="84" width="192" height="97" rx="4" fill={C.accentBg}/>

              {/* 上方雙膠片盤 */}
              <g>
                <circle cx="80" cy="55" r="34" fill="#fff" stroke={C.ink} stroke-width="2.5"/>
                <circle cx="80" cy="55" r="28" fill="none" stroke={C.ink} stroke-width="1" opacity="0.3"/>
                <circle cx="80" cy="55" r="6" fill={C.ink}/>
                {Array.from({ length: 6 }).map((_, i) => {
                  const a = (i * 60) * Math.PI / 180;
                  return <circle cx={80 + Math.cos(a) * 18} cy={55 + Math.sin(a) * 18} r="2.5" fill={C.ink} opacity="0.7"/>;
                })}
                <circle cx="180" cy="55" r="34" fill="#fff" stroke={C.ink} stroke-width="2.5"/>
                <circle cx="180" cy="55" r="28" fill="none" stroke={C.ink} stroke-width="1" opacity="0.3"/>
                <circle cx="180" cy="55" r="6" fill={C.ink}/>
                {Array.from({ length: 6 }).map((_, i) => {
                  const a = (i * 60 + 30) * Math.PI / 180;
                  return <circle cx={180 + Math.cos(a) * 18} cy={55 + Math.sin(a) * 18} r="2.5" fill={C.ink} opacity="0.7"/>;
                })}
                <line x1="80" y1="89" x2="80" y2="100" stroke={C.ink} stroke-width="2.5" stroke-linecap="round"/>
                <line x1="180" y1="89" x2="180" y2="100" stroke={C.ink} stroke-width="2.5" stroke-linecap="round"/>
              </g>

              {/* 鏡頭 */}
              <g>
                <circle cx="125" cy="132" r="38" fill={C.ink}/>
                <circle cx="125" cy="132" r="32" fill="#1A1410"/>
                <circle cx="125" cy="132" r="26" fill="none" stroke="#444" stroke-width="1"/>
                <circle cx="125" cy="132" r="20" fill={C.accentDark}/>
                <ellipse cx="118" cy="124" rx="8" ry="5" fill={C.accent} opacity="0.7"/>
                <ellipse cx="115" cy="121" rx="3" ry="2" fill="#fff" opacity="0.9"/>
                {Array.from({ length: 12 }).map((_, i) => {
                  const a = (i * 30) * Math.PI / 180;
                  return <line x1={125 + Math.cos(a) * 30} y1={132 + Math.sin(a) * 30} x2={125 + Math.cos(a) * 34} y2={132 + Math.sin(a) * 34} stroke="#fff" stroke-width="1.2" opacity="0.5"/>;
                })}
              </g>

              {/* 右側肩扛把手/監視器 */}
              <g>
                <rect x="240" y="100" width="50" height="40" rx="4" fill="#fff" stroke={C.ink} stroke-width="2.5"/>
                <rect x="245" y="105" width="40" height="26" rx="2" fill={C.ink}/>
                <rect x="248" y="108" width="34" height="20" fill={C.accent} opacity="0.7"/>
                <text x="265" y="121" font-family={sans} font-size="6" fill="#fff" text-anchor="middle" font-weight="700">REC ●</text>
                <rect x="234" y="115" width="8" height="10" fill={C.ink}/>
              </g>

              {/* 機身上的旋鈕 + REC 燈 */}
              <g>
                <circle cx="60" cy="105" r="4" fill="#DC2626"/>
                <circle cx="60" cy="105" r="6" fill="none" stroke="#DC2626" stroke-width="1" opacity="0.4"/>
                <text x="68" y="108" font-family={sans} font-size="6" fill={C.ink} font-weight="700">REC</text>
                <circle cx="200" cy="160" r="10" fill="#fff" stroke={C.ink} stroke-width="1.5"/>
                <circle cx="200" cy="160" r="6" fill={C.ink}/>
                {Array.from({ length: 8 }).map((_, i) => {
                  const a = (i * 45) * Math.PI / 180;
                  return <line x1={200 + Math.cos(a) * 7} y1={160 + Math.sin(a) * 7} x2={200 + Math.cos(a) * 9} y2={160 + Math.sin(a) * 9} stroke="#fff" stroke-width="0.8"/>;
                })}
                <rect x="55" y="155" width="80" height="20" rx="2" fill="#fff" stroke={C.ink} stroke-width="0.8"/>
                <text x="95" y="166" font-family={sans} font-size="6" fill={C.muted} text-anchor="middle" letter-spacing="1.5">DAYDREAM</text>
                <text x="95" y="173" font-family={serif} font-size="7" fill={C.ink} text-anchor="middle" font-weight="700" letter-spacing="2">DEX · STUDIO</text>
              </g>
            </svg>

            {/* 漂浮膠捲帶 */}
            <svg width="500" height="120" viewBox="0 0 500 120" style="position:absolute;bottom:-40px;right:-50px;opacity:0.85;">
              <defs>
                <path id="filmpath" d="M 10 70 Q 100 30, 200 65 T 480 50"/>
              </defs>
              <g>
                <use href="#filmpath" stroke={C.ink} stroke-width="38" fill="none" stroke-linecap="round"/>
                <use href="#filmpath" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.3"/>
              </g>
              {Array.from({ length: 14 }).map((_, i) => {
                const t = i / 13;
                const x = 10 + t * 470;
                const y = 70 - Math.sin(t * Math.PI) * 30;
                return <rect x={x - 6} y={y - 6} width="12" height="12" fill={C.bg} rx="1.5"/>;
              })}
            </svg>

            {/* 浮動小卡 — 132 位讀者 */}
