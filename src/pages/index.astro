                    <div style={`font-family:${sans};font-size:16px;font-weight:700;color:${C.ink};margin-bottom:4px;`}>{t}</div>
                    <div style={`font-family:${serif};font-size:14px;color:${C.ink2};line-height:1.7;`}>{d}</div>
                  </div>
                </div>
              ))}
            </div>
            <div style="margin-top:32px;display:flex;align-items:center;gap:16px;">
              <a href={forYouLink} style={`display:inline-flex;align-items:center;gap:8px;padding:12px 22px;background:${C.ink};color:#fff;border-radius:10px;font-family:${sans};font-size:14px;font-weight:600;text-decoration:none;`}>
                從「Python 轉職指南」開始讀 →
              </a>
              <span style={`font-family:${serif};font-size:13px;color:${C.muted};font-style:italic;`}>· 18 分鐘,慢慢看</span>
            </div>
          </div>
        </div>
      </section>

      {/* ===================== W_Newsletter ===================== */}
      <section style="padding:40px 56px 60px;max-width:1120px;margin:0 auto;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
          {/* Newsletter */}
          <div style={`padding:36px;background:${C.card};border-radius:16px;border:1px solid ${C.rule};position:relative;`}>
            <div style={`width:48px;height:48px;border-radius:12px;background:${C.accentSoft};color:${C.accentDark};display:flex;align-items:center;justify-content:center;margin-bottom:20px;`}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={C.accentDark} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/>
              </svg>
            </div>
            <h3 style={`font-family:${sans};font-size:22px;font-weight:700;color:${C.ink};margin:0 0 8px;letter-spacing:-0.3px;line-height:1.45;`}>AI 工程師與資料工程師的<br/>轉職指南</h3>
            <p style={`font-family:${serif};font-size:14px;color:${C.muted};line-height:1.85;margin:0 0 22px;`}>
              一封關於程式、職涯、AI 的長思考。每兩週寄一次 —— 這封信不會販賣焦慮,只想陪你想清楚。
            </p>
            <a href="/newsletter" style={`display:inline-flex;align-items:center;gap:8px;padding:14px 26px;background:${C.accent};color:#fff;border-radius:10px;font-family:${sans};font-size:14px;font-weight:600;text-decoration:none;box-shadow:0 4px 14px rgba(83,145,255,0.28);`}>
              免費領取
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <div style={`margin-top:14px;display:flex;align-items:center;gap:14px;font-family:${serif};font-size:12px;color:${C.faint};font-style:italic;`}>
              <span style="display:flex;align-items:center;gap:6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                隨時可以退訂
              </span>
              <span style="display:flex;align-items:center;gap:6px;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                不會被分享給任何人
              </span>
            </div>
          </div>

          {/* 1:1 諮詢 */}
          <div style={`padding:36px;background:${C.card};border-radius:16px;border:1px solid ${C.rule};`}>
            <div style={`width:48px;height:48px;border-radius:12px;background:${C.warmSoft};color:${C.warm};display:flex;align-items:center;justify-content:center;margin-bottom:20px;`}>
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={C.warm} stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18h6"/><path d="M10 22h4"/>
                <path d="M12 2a7 7 0 00-4 12.7c.8.6 1 1.3 1 2.3v1h6v-1c0-1 .2-1.7 1-2.3A7 7 0 0012 2z"/>
              </svg>
            </div>
            <h3 style={`font-family:${sans};font-size:22px;font-weight:700;color:${C.ink};margin:0 0 8px;letter-spacing:-0.3px;`}>1:1 諮詢,我陪你想清楚</h3>
            <p style={`font-family:${serif};font-size:14px;color:${C.muted};line-height:1.85;margin:0 0 18px;`}>
              50 分鐘深度對談 —— 轉職策略、履歷與作品集、職涯卡關。我不會給你標準答案,但會幫你問對問題。
            </p>
            <a href={CTA_BOOKING_URL} target="_blank" rel="noopener noreferrer" style={`display:inline-flex;align-items:center;gap:8px;padding:12px 20px;background:${C.ink};color:#fff;border-radius:10px;font-family:${sans};font-size:14px;font-weight:600;text-decoration:none;`}>
              看看時段
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <div style={`margin-top:14px;font-family:${serif};font-size:12px;color:${C.faint};font-style:italic;`}>
              · 諮詢前如果你想先聊聊,寫信給我也可以。
            </div>
          </div>
        </div>
      </section>

      <Footer />

    </div>

    {/* ===================== 右下角浮動 CTA — 領取手冊（5s 後從下方滑入，可收合到右側）===================== */}
    <aside class="floating-cta" id="newsletterCTA">
      {/* 收合按鈕（右上角 →） */}
      <button class="cta-collapse" type="button" id="ctaCollapse" aria-label="收合到右側">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 6l6 6-6 6"/>
        </svg>
      </button>

      <a
        href="/newsletter"
        class="cta-link"
        aria-label="免費領取 AI 工程師與資料工程師的轉職指南"
      >
        {/* 膠捲齒孔頂部裝飾 */}
        <div class="filmstrip">
          {Array.from({ length: 8 }).map(() => <span class="hole"></span>)}
        </div>

        <div class="cta-body">
          {/* Badge with pulsing dot */}
          <div class="badge">
            <span class="pulse-dot"></span>
            <span>FREE · 限時免費</span>
          </div>

          {/* 主標題 */}
          <div class="cta-title">
            AI 工程師與資料工程師<br/>
            <span class="highlight">的轉職指南</span>
          </div>

          {/* 副標 */}
          <div class="cta-subtitle">完整地圖 · 實戰路徑 · 慢慢看</div>

          {/* CTA 按鈕 */}
          <span class="cta-button">
            立即免費領取
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </div>
      </a>
    </aside>

    {/* 收合後的右側小標籤（信封圖示）— 點擊重新展開 */}
    <button class="cta-tab" type="button" id="newsletterTab" aria-label="展開電子報訂閱">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <path d="m2 7 10 6 10-6"/>
      </svg>
      <span class="cta-tab-label">電子報</span>
    </button>

    {/* localStorage 記住偏好 — 一次性 inline script，不阻塞 */}
    <script is:inline>
      (function () {
        const KEY = 'dd-newsletter-cta-collapsed';
        const cta = document.getElementById('newsletterCTA');
        const tab = document.getElementById('newsletterTab');
        const close = document.getElementById('ctaCollapse');
        if (!cta || !tab || !close) return;

        // 初始狀態
        if (localStorage.getItem(KEY) === '1') {
          cta.classList.add('is-collapsed');
          tab.classList.add('is-shown');
        }

        close.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          cta.classList.add('is-collapsed');
          // 等卡片滑出再顯示 tab
          setTimeout(function () { tab.classList.add('is-shown'); }, 320);
          try { localStorage.setItem(KEY, '1'); } catch (_) {}
        });

        tab.addEventListener('click', function () {
          tab.classList.remove('is-shown');
          cta.classList.remove('is-collapsed');
          try { localStorage.setItem(KEY, '0'); } catch (_) {}
        });
      })();
    </script>

    <style define:vars={{ ink: C.ink, bg: C.bg, card: C.card, rule: C.rule, accent: C.accent, accentDark: C.accentDark, warm: C.warm, warmSoft: C.warmSoft, muted: C.muted }}>
      .floating-cta {
        position: fixed;
        right: 28px;
        bottom: 22vh;
        z-index: 60;
        display: block;
        width: 360px;
        background: var(--ink);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        box-shadow:
          0 28px 70px rgba(31,27,22,0.45),
          0 10px 24px rgba(31,27,22,0.22),
          0 0 0 4px rgba(255,255,255,0.7);
        text-decoration: none;
        overflow: hidden;
        /* 進場：先藏在下方 + 淡，5s 後滑入 */
        opacity: 0;
        transform: translateY(160%) rotate(0deg);
        animation:
          ctaSlideIn 700ms cubic-bezier(0.34, 1.56, 0.64, 1) 5s forwards,
          ctaFloat 3.6s ease-in-out 5.7s infinite;
      }

      @keyframes ctaSlideIn {
        0%   { opacity: 0; transform: translateY(160%) rotate(0deg); }
        100% { opacity: 1; transform: translateY(0)    rotate(-1.5deg); }
      }
      @keyframes ctaFloat {
        0%, 100% { transform: translateY(0)    rotate(-1.5deg); }
        50%      { transform: translateY(-6px) rotate(-2.5deg); }
      }

      .floating-cta:hover {
        transform: translateY(-4px) rotate(0deg) scale(1.02) !important;
        animation-play-state: paused !important;
        transition: transform 240ms ease;
        box-shadow:
          0 32px 80px rgba(31,27,22,0.28),
          0 8px 20px rgba(31,27,22,0.12),
          0 0 0 4px rgba(255,255,255,0.7);
      }

      /* 膠捲齒孔（橘底深墨 holes，反色更顯眼） */
      .filmstrip {
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 9px 0;
        background: var(--warm);
      }
      .filmstrip .hole {
        width: 14px;
        height: 14px;
        border-radius: 3px;
        background: var(--ink);
      }

      .cta-body { padding: 24px 26px 22px; }

      /* Badge — 暖橘塊狀 */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--warm);
        color: #fff;
        border-radius: 999px;
        font-family: "Noto Sans TC", system-ui, sans-serif;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.4px;
        margin-bottom: 16px;
      }
      .pulse-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 0 rgba(255,255,255,0.7);
        animation: pulse 1.6s infinite;
      }
      @keyframes pulse {
        0%   { box-shadow: 0 0 0 0 rgba(255,255,255,0.7); }
        70%  { box-shadow: 0 0 0 10px rgba(255,255,255,0); }
        100% { box-shadow: 0 0 0 0 rgba(255,255,255,0); }
      }

      /* 主標 — 白字 */
      .cta-title {
        font-family: "Noto Sans TC", system-ui, sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.4px;
        line-height: 1.4;
        margin-bottom: 10px;
      }
      .cta-title .highlight {
        background: linear-gradient(180deg, transparent 55%, rgba(217, 119, 6, 0.55) 55%);
        padding: 0 3px;
      }

      /* 副標 — 半透明白 italic */
      .cta-subtitle {
        font-family: "Noto Serif TC", serif;
        font-size: 14px;
        color: rgba(255,255,255,0.7);
        font-style: italic;
        margin-bottom: 18px;
      }

      /* CTA Button — 暖橘填底 */
      .cta-button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 24px;
        background: var(--warm);
        color: #fff;
        border-radius: 10px;
        font-family: "Noto Sans TC", system-ui, sans-serif;
        font-size: 15px;
        font-weight: 700;
        box-shadow: 0 6px 18px rgba(217,119,6,0.45);
      }
      .floating-cta:hover .cta-button {
        background: #B8620D;
      }
      .floating-cta:hover .cta-button svg {
        transform: translateX(4px);
        transition: transform 220ms ease;
      }

      /* 收合按鈕（右上角） */
      .cta-collapse {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 2;
        width: 32px;
        height: 32px;
        border: 1px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.85);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 0;
        transition: background 160ms ease, color 160ms ease, transform 160ms ease;
      }
      .cta-collapse:hover {
        background: rgba(255,255,255,0.16);
        color: #fff;
        transform: translateX(2px);
      }

      /* a 元素 wrapper — 不要被 button 遮住 click */
      .floating-cta .cta-link {
        display: block;
        text-decoration: none;
      }

      /* 收合狀態 — 滑出右側 + 隱藏 */
      .floating-cta.is-collapsed {
        animation: none !important;
        opacity: 0 !important;
        transform: translateX(140%) rotate(0deg) !important;
        pointer-events: none !important;
        transition: transform 320ms cubic-bezier(0.55, 0, 1, 0.45), opacity 280ms ease;
      }

      /* 收合後的右側小標籤 */
      .cta-tab {
        position: fixed;
        right: 0;
        bottom: 22vh;
        z-index: 60;
        display: none;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: var(--ink);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.1);
        border-right: 0;
        border-radius: 14px 0 0 14px;
        cursor: pointer;
        font-family: "Noto Sans TC", system-ui, sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: -8px 12px 24px rgba(31,27,22,0.22);
        opacity: 0;
        transform: translateX(100%);
        transition: opacity 280ms ease, transform 320ms cubic-bezier(0.34, 1.56, 0.64, 1), background 160ms ease;
      }
      .cta-tab.is-shown {
        display: inline-flex;
        opacity: 1;
        transform: translateX(0);
      }
      .cta-tab:hover {
        background: var(--warm);
        padding-right: 20px;
      }
      .cta-tab svg {
        color: var(--warm);
        transition: color 160ms ease;
      }
      .cta-tab:hover svg { color: #fff; }

      /* 手機隱藏（避免遮內容 + RWD 衝突） */
      @media (max-width: 767px) {
        .floating-cta, .cta-tab { display: none !important; }
      }

      /* 遵守用戶 prefers-reduced-motion */
      @media (prefers-reduced-motion: reduce) {
        .floating-cta {
          animation: none !important;
          opacity: 1;
          transform: translateY(0) rotate(-1.5deg);
        }
        .pulse-dot { animation: none !important; }
      }
    </style>

  </body>
</html>
