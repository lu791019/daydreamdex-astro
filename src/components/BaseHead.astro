---
// BaseHead.astro — 全站共用的 head 元素（charset、viewport、字型、favicon、sitemap、RSS、generator）
// SEO 部分（title、description、Open Graph、Twitter Card、JSON-LD）改由 SEO.astro 負責
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Favicon (webp 為主，svg/ico 作為 fallback) -->
<link rel="icon" type="image/webp" href="/favicon.webp" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" href="/favicon.ico" />

<!-- Sitemap & RSS -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>

<meta name="generator" content={Astro.generator} />

<!-- Fonts: Noto Sans TC + Noto Serif TC -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@400;700&display=swap"
/>
