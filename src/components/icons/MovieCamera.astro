---
interface Props {
  size?: number;
  color?: string;
  class?: string;
  strokeWidth?: number;
}
const {
  size = 28,
  color = '#1F1B16',
  class: className,
  strokeWidth = 1.5,
} = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
>
  <circle cx="9" cy="6" r="3.2" />
  <circle cx="9" cy="6" r="0.9" fill={color} />
  <circle cx="17" cy="6" r="3.2" />
  <circle cx="17" cy="6" r="0.9" fill={color} />
  <path d="M9 9.2v2M17 9.2v2" />
  <rect x="3" y="11" width="18" height="11" rx="1.4" />
  <circle cx="12" cy="16.5" r="3" />
  <circle cx="12" cy="16.5" r="1.2" fill={color} opacity="0.4" />
  <rect x="18" y="13" width="2" height="2" rx="0.3" fill={color} />
  <path d="M21 14l5-2v8l-5-2z" />
  <rect x="2" y="13.5" width="2" height="3" rx="0.3" transform="translate(-1 0)" />
  <path d="M11 22v3M9 25l4-2 4 2" />
</svg>
