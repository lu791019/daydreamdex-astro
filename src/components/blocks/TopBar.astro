---
import { Icon } from 'astro-icon/components';
import {
  SITE_TITLE,
  SOCIAL_LINKS,
  CTA_BOOKING_URL,
  CTA_COURSE_URL,
} from '../../consts';

/**
 * 全站共用 TopBar
 * - activePage: 控制 7 個選單的 active 狀態
 * - showUtilityButtons: 是否顯示搜尋 + 暗色模式按鈕（index 用 true，about/coaching 用 false）
 *
 * 視覺嚴守原 inline 版本：sticky / blur / 38x38 movie camera logo / 7 menu items
 * + 5 social / utility / 一起聊聊 CTA
 */
type ActivePage =
  | '文章'
  | '關於我'
  | 'Podcast'
  | '職涯諮詢'
  | '免費課程'
  | '付費課程'
  | '電子報';

interface Props {
  activePage: ActivePage;
  showUtilityButtons?: boolean;
  /**
   * Logo 攝影機 SVG 變體（保留三頁原本的差異以達到 pixel-perfect）
   *  - 'full':    index 用，含觀景窗 + 三腳架 + 鏡頭內亮點
   *  - 'medium':  about 用，無觀景窗 / 三腳架 / 鏡頭內亮點
   *  - 'minimal': coaching 用，比 medium 再少鏡頭內亮點與膠片中心點
   */
  logoVariant?: 'full' | 'medium' | 'minimal';
}

const {
  activePage,
  showUtilityButtons = false,
  logoVariant = 'full',
} = Astro.props;

const C = {
  bg: '#FBFAF7',
  bgSoft: '#F4F1EB',
  ink: '#1F1B16',
  ink2: '#3D3A33',
  muted: '#6B6557',
  rule: '#E8E2D4',
  accent: '#5391FF',
  accentDark: '#2F6FE0',
  accentSoft: '#EAF1FF',
  warm: '#D97706',
};
const sans = '"Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif';
const serif = '"Noto Serif TC", "Source Han Serif TC", serif';

type IconKey = 'mic' | 'calendar' | 'graduation' | 'sparkle' | null;
interface NavItem {
  label: ActivePage;
  href: string;
  icon: IconKey;
}
const navItems: NavItem[] = [
  { label: '文章', href: '/', icon: null },
  { label: '關於我', href: '/about', icon: null },
  {
    label: 'Podcast',
    href: 'https://open.spotify.com/show/2qV49EUjFOcJIqkUjwmu2T',
    icon: 'mic',
  },
  { label: '職涯諮詢', href: '/coaching', icon: 'calendar' },
  { label: '免費課程', href: '#', icon: 'graduation' },
  { label: '付費課程', href: CTA_COURSE_URL, icon: 'sparkle' },
  { label: '電子報', href: '/newsletter', icon: null },
];
---
<div
  style={`position:sticky;top:0;z-index:50;background:rgba(251,250,247,0.94);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid ${C.rule};`}
>
  <div style="max-width:1240px;margin:0 auto;padding:14px 48px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
    {/* Logo */}
    <a
      href="/"
      style="display:flex;align-items:center;gap:12px;flex-shrink:0;text-decoration:none;"
    >
      <div
        style={`width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg, ${C.accent}, ${C.accentDark});display:flex;align-items:center;justify-content:center;position:relative;`}
      >
        <svg
          width="22"
          height="22"
          viewBox="0 0 32 32"
          fill="none"
          stroke="#fff"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="9" cy="6" r="3.2" />
          <circle cx="9" cy="6" r="0.9" fill="#fff" />
          <circle cx="17" cy="6" r="3.2" />
          <circle cx="17" cy="6" r="0.9" fill="#fff" />
          <path d="M9 9.2v2M17 9.2v2" />
          <rect x="3" y="11" width="18" height="11" rx="1.4" />
          <circle cx="12" cy="16.5" r="3" />
          {logoVariant !== 'minimal' && (
            <circle cx="12" cy="16.5" r="1.2" fill="#fff" opacity="0.4" />
          )}
          <rect x="18" y="13" width="2" height="2" rx="0.3" fill="#fff" />
          <path d="M21 14l5-2v8l-5-2z" />
          {logoVariant === 'full' && (
            <>
              <rect x="1" y="13.5" width="2" height="3" rx="0.3" />
              <path d="M11 22v3M9 25l4-2 4 2" />
            </>
          )}
        </svg>
        <div
          style={`position:absolute;top:-3px;right:-3px;width:10px;height:10px;border-radius:50%;background:${C.warm};border:2px solid ${C.bg};`}
        ></div>
      </div>
      <div>
        <div
          style={`font-family:${sans};font-size:15px;font-weight:700;color:${C.ink};line-height:1;letter-spacing:-0.2px;`}
        >
          {SITE_TITLE}
        </div>
        <div
          style={`font-family:${serif};font-size:10.5px;color:${C.muted};margin-top:3px;font-style:italic;`}
        >
          白日夢的塵世筆記
        </div>
      </div>
    </a>

    {/* 主選單 */}
    <nav
      style={`display:flex;align-items:center;gap:2px;font-family:${sans};font-size:13.5px;flex:1;justify-content:center;`}
    >
      {navItems.map((it) => {
        const active = it.label === activePage;
        return (
          <a
            href={it.href}
            style={`color:${active ? C.ink : C.ink2};padding:8px 12px;border-radius:8px;text-decoration:none;font-weight:${active ? 600 : 500};background:${active ? C.accentSoft : 'transparent'};display:inline-flex;align-items:center;gap:6px;white-space:nowrap;`}
          >
            {it.icon === 'mic' && (
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke={active ? C.accent : C.muted}
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="9" y="2" width="6" height="12" rx="3" />
                <path d="M5 11a7 7 0 0014 0M12 18v3M9 21h6" />
              </svg>
            )}
            {it.icon === 'calendar' && (
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke={active ? C.accent : C.muted}
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="18" height="18" rx="2" />
                <path d="M16 2v4M8 2v4M3 10h18" />
              </svg>
            )}
            {it.icon === 'graduation' && (
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke={active ? C.accent : C.muted}
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M2 9l10-5 10 5-10 5L2 9z" />
                <path d="M6 11v5c3.5 2 8.5 2 12 0v-5" />
              </svg>
            )}
            {it.icon === 'sparkle' && (
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke={active ? C.accent : C.muted}
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" />
              </svg>
            )}
            {it.label}
          </a>
        );
      })}
    </nav>

    {/* 右側：社群 + utility + CTA */}
    <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
      <div
        style={`display:flex;align-items:center;gap:2px;padding:4px 6px;background:${C.bgSoft};border-radius:999px;`}
      >
        {SOCIAL_LINKS.map((s) => (
          <a
            href={s.url}
            title={s.name}
            target="_blank"
            rel="noopener noreferrer"
            style={`width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:${C.muted};text-decoration:none;`}
          >
            <Icon name={s.icon} width={14} height={14} />
          </a>
        ))}
      </div>
      <span
        style={`width:1px;height:18px;background:${C.rule};margin:0 6px;`}
      ></span>
      {showUtilityButtons && (
        <>
          <button
            title="搜尋"
            style={`width:34px;height:34px;border-radius:8px;border:none;background:transparent;color:${C.muted};cursor:pointer;display:flex;align-items:center;justify-content:center;`}
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <circle cx="11" cy="11" r="7" />
              <path d="M21 21l-4.35-4.35" />
            </svg>
          </button>
          <button
            title="暗色模式"
            style={`width:34px;height:34px;border-radius:8px;border:none;background:transparent;color:${C.muted};cursor:pointer;display:flex;align-items:center;justify-content:center;`}
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
            </svg>
          </button>
        </>
      )}
      <a
        href={CTA_BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        style={`margin-left:6px;padding:9px 16px;background:${C.ink};color:#fff;font-size:13px;font-weight:500;border-radius:8px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;`}
      >
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#fff"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 8a2 2 0 012-2h14a2 2 0 012 2v2a2 2 0 000 4v2a2 2 0 01-2 2H5a2 2 0 01-2-2v-2a2 2 0 000-4z" />
          {showUtilityButtons && (
            <path d="M11 6v12" stroke-dasharray="1.5 2" />
          )}
        </svg>
        一起聊聊
      </a>
    </div>
  </div>
</div>
